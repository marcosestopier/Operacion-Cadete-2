rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'isRegistered']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.name is string && data.name.size() < 100;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['uid', 'date', 'type', 'title']) &&
             data.uid == request.auth.uid &&
             data.title is string && data.title.size() < 200;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /metadata/stats {
      allow read: if true; // Stats are public aggregate data
      allow update: if isAuthenticated(); // Users can update stats on registration
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidHistory(request.resource.data);
      allow delete: if false; // As requested, no option to reset/delete history
    }
  }
}
